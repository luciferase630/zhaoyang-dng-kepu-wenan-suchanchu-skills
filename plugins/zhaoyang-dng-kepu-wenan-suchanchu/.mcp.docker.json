{
  "mcpServers": {
    "excalidraw": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "EXPRESS_SERVER_URL=http://host.docker.internal:3000",
        "-e",
        "ENABLE_CANVAS_SYNC=true",
        "ghcr.io/yctimlin/mcp_excalidraw:latest"
      ]
    }
  }
}
